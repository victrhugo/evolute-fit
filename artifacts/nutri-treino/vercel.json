{
  "buildCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm --filter @workspace/nutri-treino run build",
  "outputDirectory": "dist/public",
  "installCommand": "echo skip",
  "framework": null,
  "functions": {
    "api/chat.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "env": {
    "APP_URL": "@app_url"
  }
}
