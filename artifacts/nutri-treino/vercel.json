{
  "buildCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm --filter @workspace/nutri-treino run build",
  "outputDirectory": "dist/public",
  "installCommand": "echo 'skip'",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "APP_URL": "@app_url"
  }
}
